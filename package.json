{
    "name": "beg-management",
    "private": true,
    "workspaces": [
        "apps/app",
        "apps/api",
        "packages/*"
    ],
    "scripts": {
        "dev": "docker compose up --watch",
        "desktop:dev": "cd apps/desktop && bun run dev",
        "desktop:release": "cd apps/desktop && bun run release",
        "docker:build": "./scripts/build-docker.sh",
        "lint:app": "bun run --cwd apps/app lint",
        "lint:api": "bun run --cwd apps/api lint",
        "lint:check:app": "bun run --cwd apps/app lint:check",
        "lint:check:api": "bun run --cwd apps/api lint:check",
        "test:api": "docker compose exec api bun test --timeout 30000",
        "test:api:coverage": "docker compose exec api bun test --timeout 30000 --coverage",
        "type-check:app": "bun run --cwd apps/app type-check",
        "type-check:api": "bun run --cwd apps/api type-check"
    },
    "module": "index.ts",
    "type": "module",
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5.0.0"
    }
}